{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Trust core = trip CRUD + transfer serialize/merge (the intent fuzzer's targets). Survivors are a work queue, never a gate. Incremental only. See stack/stryker.md.",
  "packageManager": "npm",
  "testRunner": "jest",
  "jest": {
    "projectType": "custom",
    "configFile": "package.json",
    "enableFindRelatedTests": false
  },
  "coverageAnalysis": "perTest",
  "incremental": true,
  "incrementalFile": "stryker-incremental.json",
  "reporters": [
    "json",
    "clear-text"
  ],
  "concurrency": 2,
  "timeoutMS": 20000,
  "mutate": [
    "src/store/trips.ts",
    "src/lib/transfer.ts"
  ],
  "ignorePatterns": [
    "ios",
    "android",
    ".expo",
    ".stryker-tmp",
    "dist",
    "build",
    "reports",
    "coverage",
    "store-assets",
    "qa/captures"
  ]
}
