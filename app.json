{
  "expo": {
    "name": "Packing List",
    "slug": "packing-list",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.joshapproved.packinglist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleName": "Packing List"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAFAF7"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.joshapproved.packinglist"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "owner": "josh-approved",
    "plugins": [
      "expo-font",
      "expo-sqlite",
      "expo-iap",
      "./plugins/withGradleJvmArgs",
      "expo-mail-composer"
    ],
    "extra": {
      "eas": {
        "projectId": "e06be526-70b4-4356-ab60-ec563f1f63c8"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e06be526-70b4-4356-ab60-ec563f1f63c8"
    }
  }
}
